# Application
APP_NAME=企业级 AI 知识助手
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# DashScope (used from Phase 2)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_EMBEDDING_DIMENSIONS=1024
DASHSCOPE_RERANK_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
DASHSCOPE_RERANK_MODEL=qwen3-rerank
DASHSCOPE_TIMEOUT_SECONDS=30
DASHSCOPE_MAX_RETRIES=2

# Local storage (used from Phase 5)
MILVUS_URI=./milvus/knowledge.db
MILVUS_TOKEN=
MILVUS_COLLECTION_NAME=knowledge_chunks
MILVUS_TIMEOUT_SECONDS=30

# RAG
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=120
RAG_EMBEDDING_BATCH_SIZE=10
RAG_INSERT_BATCH_SIZE=100
RAG_INITIAL_TOP_K=20
RAG_FINAL_TOP_K=5
RAG_MAX_CONTEXT_CHARS=8000
RAG_MAX_ANSWER_TOKENS=1200
RAG_MAX_FILE_SIZE_MB=20

# Tools
TAVILY_API_KEY=
TOOL_HTTP_TIMEOUT_SECONDS=10
TOOL_MAX_RETRIES=2
SEARCH_MAX_CONTENT_CHARS=1500
DATABASE_PATH=./data/assistant.db
DATABASE_MAX_ROWS=100
DATABASE_TIMEOUT_SECONDS=5

# Agent
AGENT_MAX_TOOL_CALLS=5
AGENT_MEMORY_TURNS=6
AGENT_MEMORY_MAX_CHARS=12000
AGENT_MAX_OBSERVATION_CHARS=6000
AGENT_MAX_ANSWER_TOKENS=1200

# LangGraph Workflow
WORKFLOW_RETRIEVAL_TOP_K=5
WORKFLOW_MAX_ANSWER_TOKENS=1200
