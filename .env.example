# Application
APP_NAME=企业级 AI 知识助手
APP_ENV=development
DEBUG=false
LOG_LEVEL=INFO

# DashScope (used from Phase 2)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_CHAT_MODEL=qwen-plus
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v3
DASHSCOPE_TIMEOUT_SECONDS=30
DASHSCOPE_MAX_RETRIES=2

# Local storage (used from Phase 5)
MILVUS_URI=./milvus/knowledge.db
